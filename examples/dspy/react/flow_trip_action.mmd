%% 行程操作骨架——完整說明見同目錄 README.md
%% (mermaid v11 對開頭多行 %% 註解區塊解析不穩定,故此檔只留最短單行註解)

flowchart TD

    %% ---- 意圖:查詢 ----
    startQuery(["已知意圖:查詢"]) --> callTripEntryListForQuery[["trip_entry_list"]]
    callTripEntryListForQuery --> replyQueried(("回覆:已載入"))

    %% ---- 意圖:推薦(底下再分兩種子情境,都不接著寫入行程) ----
    startRecommend(["已知意圖:推薦"]) --> recommendKind{"鄰近推薦或開放式提問(有什麼地方可以去)?"}

    recommendKind -->|鄰近推薦| callRecommendNearbyTop[["recommend_nearby"]]
    callRecommendNearbyTop --> replyRecommendedNearby(("回覆:推薦"))

    recommendKind -->|開放式提問| callRecommendOpen[["recommend_nearby"]]
    callRecommendOpen --> replyRecommendedOpen(("回覆:推薦地點"))

    %% ---- 意圖:想去哪裡(先判斷目的地範圍) ----
    startDestination(["已知意圖:想去哪裡"]) --> destinationScope{"目的地是大區域或特定定點?"}

    destinationScope -->|大區域| askUserDestinationRecommend[["ask_user"]]
    askUserDestinationRecommend --> userWantsDestinationRecommend{"使用者同意推薦?"}
    userWantsDestinationRecommend -->|同意| callRecommendDestination[["recommend_nearby"]]
    callRecommendDestination --> replyDestinationRecommended(("回覆:推薦行程"))
    userWantsDestinationRecommend -->|不同意| askUserDetailedItinerary[["ask_user"]]
    askUserDetailedItinerary --> replyAskDetailedItinerary(("回覆:詢問詳細行程"))

    destinationScope -->|特定定點| callTripEntryAddDestination[["trip_entry_add"]]
    callTripEntryAddDestination --> replyDestinationAdded(("回覆:已記下"))

    %% ---- 意圖:規劃(合併原情況 A 新增與情況 C 更新) ----
    startPlan(["已知意圖:規劃"]) --> callTripEntryList[["trip_entry_list"]]
    callTripEntryList --> listResult{"找到幾筆?"}

    listResult -->|多筆| askChoiceWhich[["ask_choice"]]
    askChoiceWhich --> callTripEntryUpdateFromChoice[["trip_entry_update"]]
    callTripEntryUpdateFromChoice --> replyUpdated(("回覆:已更新"))
    listResult -->|1筆| dupCheckUpdate{"改完會跟其他條目重複?"}
    dupCheckUpdate -->|是| askUserDupUpdate[["ask_user"]]
    askUserDupUpdate --> replyDupConfirm(("回覆:確認重複"))
    dupCheckUpdate -->|否| callTripEntryUpdate[["trip_entry_update"]]
    callTripEntryUpdate --> replyUpdated2(("回覆:已更新"))

    listResult -->|0筆| hasLocation{"有明確可定位地點?"}

    hasLocation -->|單一地點| callGeocode[["geocode"]]
    callGeocode --> callTripEntryAddWithGeo[["trip_entry_add"]]
    callTripEntryAddWithGeo --> replyAddedWithGeo(("回覆:已記下且座標"))

    hasLocation -->|區域,非單一地點| askUserRecommend[["ask_user"]]
    askUserRecommend --> userWantsRecommend{"使用者同意推薦?"}
    userWantsRecommend -->|同意| callRecommendNearby[["recommend_nearby"]]
    callRecommendNearby --> callTripEntryAddWithRecommend[["trip_entry_add"]]
    callTripEntryAddWithRecommend --> replyAddedWithRecommend(("回覆:已記下且推薦"))
    userWantsRecommend -->|不同意| callTripEntryAddNoRecommend[["trip_entry_add"]]
    callTripEntryAddNoRecommend --> replyAddedNoRecommend(("回覆:已記下"))

    hasLocation -->|無地點| callTripEntryAddNoLocation[["trip_entry_add"]]
    callTripEntryAddNoLocation --> replyAddedPlain(("回覆:已記下"))
